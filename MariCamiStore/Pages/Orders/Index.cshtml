@page
@model MariCamiStore.Pages.Orders.IndexModel
@{
}

<section class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6"><h1>Órdenes</h1></div>
            <div class="col-sm-6 text-right">
                <select id="statusFilter" class="form-control d-inline-block" style="width:auto;">
                    <option value="Pending,Active">Pendientes y Activas</option>
                    <option value="Delivering,Delivered">En Entrega</option>
                    <option value="Completed">Completadas</option>
                    <option value="Voided">Anuladas</option>
                    <option value="">Todas</option>
                </select>
            </div>
        </div>
    </div>
</section>

<section class="content">
    <div class="card">
        <div class="card-header">
            <h3 class="card-title">Lista de Órdenes</h3>
            <div class="card-tools">
                <button id="btn-new-order" class="btn btn-primary btn-sm">
                    <i class="fas fa-plus"></i> Nueva Orden
                </button>
            </div>
        </div>
        <div class="card-body">
            <div id="jsGrid"></div>
        </div>
    </div>
</section>

<!-- New/Edit Order Modal -->
<div class="modal fade" id="orderModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Orden</h5>
                <button type="button" class="close" data-dismiss="modal">&times;</button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="order-id" />
                <div class="row">
                    <div class="col-md-4">
                        <div class="form-group">
                            <label>Proveedor</label>
                            <select id="order-supplier" class="form-control"></select>
                        </div>
                    </div>
                    <div class="col-md-8">
                        <div class="form-group">
                            <label>Nombre de la Orden</label>
                            <input id="order-name" type="text" class="form-control" />
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-3">
                        <div class="form-group">
                            <label>Moneda</label>
                            <select id="order-currency" class="form-control"></select>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="form-group">
                            <label>Tipo de Cambio</label>
                            <input id="order-exchange-rate" type="number" step="0.01" class="form-control" />
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="form-group">
                            <label>Impuesto (%)</label>
                            <input id="order-tax" type="number" step="0.01" class="form-control" />
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="form-group edit-only-field">
                            <label>Envío Intern.</label>
                            <input id="order-shipping-intern" type="number" step="0.01" value="0" class="form-control" />
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-3">
                        <div class="form-group edit-only-field">
                            <label>Descuento</label>
                            <input id="order-discount" type="number" step="0.01" value="0" class="form-control" />
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancelar</button>
                <button id="btn-save-order" type="button" class="btn btn-primary">Guardar</button>
            </div>
        </div>
    </div>
</div>

<!-- Transition Modal -->
<div class="modal fade" id="transitionModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Cambiar Estado</h5>
                <button type="button" class="close" data-dismiss="modal">&times;</button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="transition-order-id" />
                <input type="hidden" id="transition-to-status" />
                <div class="form-group">
                    <label>Fecha</label>
                    <input id="transition-date" type="date" class="form-control" />
                </div>
                <div class="form-group">
                    <label>Notas (opcional)</label>
                    <textarea id="transition-notes" class="form-control" rows="2"></textarea>
                </div>
                <div class="form-group" id="justification-group" style="display:none;">
                    <label>Justificación <span class="text-danger">*</span></label>
                    <textarea id="transition-justification" class="form-control" rows="3"></textarea>
                </div>
                <div class="form-group" id="actual-shipping-group" style="display:none;">
                    <label>Shipping real a CR</label>
                    <input id="actual-shipping-amount" type="number" step="0.01" min="0" class="form-control" />
                </div>
                <div id="transition-error" class="text-danger" style="display:none;"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancelar</button>
                <button id="btn-confirm-transition" type="button" class="btn btn-warning">Confirmar</button>
            </div>
        </div>
    </div>
</div>

<script>var localCurrencySign = @Html.Raw(Json.Serialize(ViewData["LocalCurrencySign"]));</script>
<script src="/js/pages/orders/index.js"></script>
